# =============================================
#  CodeArena — Environment Variables
# =============================================
# Copy this file:  cp .env.example .env
# Then fill in the values below.
# The .env file is used by docker-compose AND
# can be sourced for local (non-Docker) dev.
# =============================================

# ----- REQUIRED -----

# MySQL
DB_USERNAME=root
DB_PASSWORD=your-db-password
DB_URL=jdbc:mysql://db:3306/codestorm?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&useUnicode=true

# JWT (use a long random string, min 32 chars)
JWT_SECRET=change-me-to-a-strong-random-secret

# ----- OPTIONAL — Feature Toggles -----

# Google OAuth2 login
# To enable: set SPRING_PROFILES_ACTIVE=oauth and supply keys below
SPRING_PROFILES_ACTIVE=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini AI (code hints, plagiarism detection, mock interviews)
GEMINI_API_KEY=

# Email OTP verification via Gmail SMTP (set MAIL_ENABLED=true to enable)
MAIL_ENABLED=false
MAIL_USERNAME=
MAIL_PASSWORD=

# ----- OPTIONAL — Overrides (sensible defaults already set) -----

# CORS origin the backend will accept (default: http://localhost:5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Where the frontend redirects after OAuth2 login
OAUTH_SUCCESS_REDIRECT=http://localhost:5173/oauth2/callback

# Set to true in production (HTTPS-only cookies)
COOKIE_SECURE=false

# Frontend API base URL (used at build time by Vite)
VITE_BASE_URL=http://localhost:8080/api

# Show Google OAuth button on login page (set to true when OAuth is configured)
VITE_OAUTH_ENABLED=false

// Configure SSH credential for App EC2
// Run via Jenkins CLI after plugins are installed

import jenkins.model.*
import com.cloudbees.plugins.credentials.*
import com.cloudbees.plugins.credentials.domains.*
import com.cloudbees.jenkins.plugins.sshcredentials.impl.*

def credId = "app-ec2-ssh-key"
def store = SystemCredentialsProvider.getInstance().getStore()

// Remove existing credential if already present (idempotent)
store.getCredentials(Domain.global()).find { it.id == credId }?.with {
    store.removeCredentials(Domain.global(), it)
}

def privateKey = """{{ app_ec2_pem_key | indent(0) }}"""

def credential = new BasicSSHUserPrivateKey(
    CredentialsScope.GLOBAL,
    credId,
    "ubuntu",
    new BasicSSHUserPrivateKey.DirectEntryPrivateKeySource(privateKey),
    "",
    "App EC2 SSH Key"
)

store.addCredentials(Domain.global(), credential)
println "✅ SSH credential '${credId}' configured"

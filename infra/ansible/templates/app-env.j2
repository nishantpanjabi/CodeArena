# =============================================
#  CodeArena — Environment Variables
# =============================================
# Generated by Ansible — DO NOT edit manually
# Edit group_vars/all.yml and re-run site.yml
# =============================================

# MySQL
DB_USERNAME={{ app_db_username }}
DB_PASSWORD={{ app_db_password }}
DB_PORT=3307

# JWT (min 32 chars)
JWT_SECRET={{ app_jwt_secret }}

# Google OAuth2 (leave empty to disable)
SPRING_PROFILES_ACTIVE={{ app_spring_profiles }}
OAUTH_ENABLED={{ 'true' if app_spring_profiles == 'oauth' else 'false' }}
GOOGLE_CLIENT_ID={{ app_google_client_id }}
GOOGLE_CLIENT_SECRET={{ app_google_client_secret }}

# Gemini AI
GEMINI_API_KEY={{ app_gemini_api_key }}

# Email OTP
MAIL_ENABLED={{ app_mail_enabled }}
MAIL_USERNAME={{ app_mail_username }}
MAIL_PASSWORD={{ app_mail_password }}

# Production overrides
CORS_ALLOWED_ORIGINS=http://{{ app_public_ip }}
OAUTH_SUCCESS_REDIRECT=http://{{ app_public_ip }}/oauth2/callback
COOKIE_SECURE={{ app_cookie_secure }}
VITE_BASE_URL=http://{{ app_public_ip }}/api
VITE_OAUTH_ENABLED={{ 'true' if app_spring_profiles == 'oauth' else 'false' }}
